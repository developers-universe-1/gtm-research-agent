# ───────────────────────────────────────────────
# MCP Sales Agent — Environment Configuration
# ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Demo mode works without any of these — just cp .env.example .env and run.

# ─── LLM Provider ───
# Required for live analysis mode (demo mode works without this)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Database ───
# Required for persistence in production (demo uses in-memory cache)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/mcp_sales_agent

# ─── MCP Transport ───
# Set to 'stdio' for CLI integration, 'sse' for HTTP streaming
# Default: sse
MCP_TRANSPORT=sse

# ─── Salesforce ───
# OAuth2 credentials from your Salesforce Connected App
# Required for pipeline update tool
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3000/api/auth/salesforce/callback

# ─── HubSpot ───
# Private app token from HubSpot Settings > Integrations > Private Apps
# Required for HubSpot pipeline tool
HUBSPOT_PRIVATE_APP_TOKEN=

# ─── Gong ───
# API key from Gong Settings > API
# Required for call ingestion tool
GONG_API_KEY=

# ─── Slack ───
# Webhook URL for notifications
# Get it at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Gmail / Outlook ───
# OAuth2 credentials for follow-up draft/send tool
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
